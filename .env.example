# Mastodon (from your instance's Settings → Development → New Application)
MASTODON_CLIENT_KEY=
MASTODON_CLIENT_SECRET=
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE_URL=https://mastodon.social

# Google APIs (from console.cloud.google.com)
# Enable: Street View Static API
GOOGLE_API_KEY=

# Mapillary (optional — fallback images when Street View has no coverage)
# Get a free token at mapillary.com/developer
MAPILLARY_ACCESS_TOKEN=

# Health checks (optional — ping this URL on each successful post)
# Create a free check at healthchecks.io
HEALTHCHECK_URL=
